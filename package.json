{
  "name": "xiaotie",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c auto \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 XIAOTIE_USERDATA_DIR=.xiaotie-dev-userdata electron . --no-sandbox",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.3",
    "typescript": "~5.6.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.xiaotie.app",
    "productName": "小贴",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "src-tauri/icons/icon.icns"
    }
  }
}
